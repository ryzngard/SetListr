@page "/setlist/{id}"
@using Microsoft.AspNetCore.Mvc
@inject SetListApiClient SetListApiClient

@if (SetList is null)
{
    <FluentProgressRing></FluentProgressRing>
}
else 
{
    <FluentHeader>
        @SetList.Name
        <FluentDivider />
        @SetList.Duration
    </FluentHeader>
    <FluentDataGrid Items="@Songs">
        <TemplateColumn Title="Name" Sortable="true" Align="Align.Start">
            @context.Name
        </TemplateColumn>
        <PropertyColumn Property="@(p => p.Duration)" Sortable="true" />
    </FluentDataGrid>
}

@code {
    [Parameter] public string Id { get; set; }

    SetList? SetList { get; set; }

    IQueryable<Song>? Songs { get; set; }

    protected override async Task OnInitializedAsync()
    {
        if (Guid.TryParse(Id, out var guidId))
        {
            SetList = await SetListApiClient.GetSetListAsync(guidId);
            Songs = SetList.Songs.ToArray().AsQueryable();
        }
    }
}
